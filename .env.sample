# Logging: verbose | debug | info | warning | error
LOG_LEVEL=info

# On-prem server URL (optional if you pass --server-url on the command line)
AZURE_DEVOPS_SERVER_URL=https://devops.suizer.com

# Docker Compose
ADO_MCP_PORT=8000
ADO_MCP_ORGANIZATION=_
ADO_MCP_AUTH=ntlm

# NTLM auth (-a ntlm)
ADO_MCP_USERNAME="suizer\your.user"
ADO_MCP_PASSWORD=your-domain-password

# PAT auth (-a pat) — base64 of "email:token"
# PERSONAL_ACCESS_TOKEN=
